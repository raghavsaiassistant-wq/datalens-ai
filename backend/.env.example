# Copy this to .env and fill in your real keys
# NEVER commit .env to git

# NVIDIA NIM API KEYS (one per model)
KEY_LLAMA_70B=nvapi-YOUR_KEY_HERE
KEY_KIMI_K2=nvapi-YOUR_KEY_HERE
KEY_MINIMAX=nvapi-YOUR_KEY_HERE
KEY_EMBEDQA=nvapi-YOUR_KEY_HERE
KEY_EMBEDQA_MULTI=nvapi-YOUR_KEY_HERE
KEY_MISTRAL=nvapi-YOUR_KEY_HERE
KEY_LLAMA_8B=nvapi-YOUR_KEY_HERE
KEY_LLAMA_GUARD=nvapi-YOUR_KEY_HERE
KEY_OCR=nvapi-YOUR_KEY_HERE
KEY_PAGE_ELEMENTS=nvapi-YOUR_KEY_HERE
KEY_TABLE_STRUCTURE=nvapi-YOUR_KEY_HERE
KEY_QWEN_VL=nvapi-YOUR_KEY_HERE

# APP CONFIG
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
FLASK_PORT=5000
FLASK_ENV=development
MAX_FILE_SIZE_MB=25
